{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "dist",
    "resolveJsonModule": true
  },
  "include": [
    "server.ts",
    "src/db/**/*",
    "src/middleware/**/*",
    "src/lib/**/*",
    "src/types.ts"
  ],
  "exclude": [
    "src/db/drizzle.config.ts",
    "src/lib/firebase.ts",
    "src/main.tsx",
    "src/App.tsx",
    "src/components/**/*"
  ]
}